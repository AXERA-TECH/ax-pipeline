{
  "system": {
    "device_id": -1,
    "enable_vdec": true,
    "enable_venc": true,
    "enable_ivps": true
  },
  "pipelines": [
    {
      "name": "p0",
      "device_id": -1,
      "uri": "/path/to/input.mp4",
      "realtime_playback": false,
      "loop_playback": false,
      "npu_max_fps": 20,
      "log_every_n_frames": 30,
      "frame_output": {
        "format": "bgr",
        "width": 640,
        "height": 640,
        "resize": {
          "mode": "keep_aspect",
          "horizontal_align": "center",
          "vertical_align": "center",
          "background_color": 0
        }
      },
      "outputs": [
        {
          "codec": "h264",
          "uris": [
            "/tmp/p0_out.mp4"
          ]
        }
      ]
    }
  ]
}
